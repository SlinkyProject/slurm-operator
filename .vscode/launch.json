{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Operator",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceRoot}/cmd/manager/main.go",
      "env": {
        "DEBUG": "1"
      },
      "args": [
        "--zap-log-level=5"
      ]
    },
     {
      "name": "Launch Webhook",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceRoot}/cmd/webhook/main.go",
      "args": [
        "--zap-log-level=5"
      ],
      "preLaunchTask": "Setup Webhook Debugging",
      "postDebugTask": "Revert Webhook Debugging"
    },
    {
      "name": "Debug Operator",
      "type": "go",
      "request": "attach",
      "mode": "remote",
      "host": "127.0.0.1",
      "port": 40003,
      "substitutePath": [
        { "from": "${workspaceFolder}", "to": "/workspace" }
      ]
    },
    {
      "name": "Debug Webhook",
      "type": "go",
      "request": "attach",
      "mode": "remote",
      "host": "127.0.0.1",
      "port": 40004,
      "substitutePath": [
        { "from": "${workspaceFolder}", "to": "/workspace" }
      ]
    }
  ]
}
